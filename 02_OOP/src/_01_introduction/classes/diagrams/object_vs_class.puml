@startuml object_vs_class
title Klasa jako szablon - obiekty jako instancje

skinparam class {
    BackgroundColor LightBlue
    BorderColor Navy
}
skinparam object {
    BackgroundColor LightGreen
    BorderColor DarkGreen
}

class Dog {
    name : String
    breed : String
    age : int
    bark()
    describe()
}

object "rex : Dog" as rex {
    name = "Rex"
    breed = "Owczarek Niemiecki"
    age = 3
}

object "buddy : Dog" as buddy {
    name = "Buddy"
    breed = "Labrador"
    age = 1
}

object "luna : Dog" as luna {
    name = "Luna"
    breed = "Beagle"
    age = 2
}

Dog ..> rex  : <<creates>>
Dog ..> buddy : <<creates>>
Dog ..> luna : <<creates>>

note bottom of Dog
  <b>Jedna klasa</b> → wiele obiektów
  Każdy obiekt ma <b>własne wartości pól</b>
  (niezależne kopie danych)
end note

@enduml

