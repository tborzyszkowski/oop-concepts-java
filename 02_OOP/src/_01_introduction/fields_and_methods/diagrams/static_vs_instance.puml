@startuml static_vs_instance
title Pola statyczne vs instancyjne - model pamieci

skinparam backgroundColor #FAFAFA
skinparam rectangle {
    RoundCorner 8
}

rectangle "Metaspace / Class Area\n(pamiec klasy)" as meta #LightBlue {
    rectangle "Counter.class" as cls #AliceBlue {
        rectangle "static int instanceCount = 3\nJedna kopia dla calej klasy" as sf #LightSkyBlue
        rectangle "static final int DEFAULT_MAX = 100\nStala klasy" as sc #LightSkyBlue
    }
}

rectangle "Heap (Sterta)" as heap #LightGreen {
    rectangle "c1 : Counter" as obj1 #PaleGreen {
        rectangle "name = \"Zamowienia\"\ncount = 3\nminValue = 0\nmaxValue = 10\n(pola instancyjne c1)" as f1 #Honeydew
    }
    rectangle "c2 : Counter" as obj2 #PaleGreen {
        rectangle "name = \"Wizyty\"\ncount = 0\nminValue = 0\nmaxValue = 100\n(pola instancyjne c2)" as f2 #Honeydew
    }
    rectangle "c3 : Counter" as obj3 #PaleGreen {
        rectangle "name = \"Bledy\"\ncount = 0\nminValue = 0\nmaxValue = 50\n(pola instancyjne c3)" as f3 #Honeydew
    }
}

obj1 ..> meta : Counter.instanceCount++\n(przy new Counter)
obj2 ..> meta
obj3 ..> meta

note bottom of heap
  Kazdy obiekt ma WLASNA kopie
  pol instancyjnych (name, count, ...)
  Pole statyczne instanceCount = 3
  jest <b>jedno</b> dla wszystkich!
end note

@enduml
