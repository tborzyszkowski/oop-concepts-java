@startuml switch_evolution
title Ewolucja instrukcji switch w Javie

skinparam note {
    BackgroundColor #FFFDE7
    BorderColor #F9A825
}
skinparam rectangle {
    BackgroundColor #E8F5E9
    BorderColor #388E3C
    RoundCorner 10
}

rectangle "Java <= 13\nswitch statement" as v1 #FFE0E0 {
    note as n1
        switch (day) {
          case 1:
            name = "Pon";
            break;
          default:
            name = "Inny";
        }
        Pulapki: Fall-through, brak wartosci
    end note
}

rectangle "Java 14+\nswitch expression" as v2 #FFF9C4 {
    note as n2
        String name = switch (day) {
            case 1  -> "Poniedzialek";
            case 2  -> "Wtorek";
            default -> "Inny";
        };
        Zalety: wartosc zwracana,
        brak fall-through
    end note
}

rectangle "Java 21\nPattern Matching" as v3 #E8F5E9 {
    note as n3
        double area = switch (shape) {
            case Circle c ->
              Math.PI * c.radius() * c.radius();
            case Rectangle r ->
              r.width() * r.height();
            case Triangle t when t.base() > 0 ->
              0.5 * t.base() * t.height();
        };
        Zalety: typy, guarded patterns, sealed
    end note
}

v1 -right-> v2 : Java 14\n(preview)\nJava 16\n(stable)
v2 -right-> v3 : Java 21\nJEP 441\n(stable)

@enduml
