@startuml switch_evolution
title Ewolucja instrukcji switch w Javie

skinparam note {
    BackgroundColor #FFFDE7
    BorderColor #F9A825
}
skinparam rectangle {
    BackgroundColor #E8F5E9
    BorderColor #388E3C
    RoundCorner 10
}

rectangle "Java ≤ 13\nswitch statement" as v1 #FFE0E0 {
    note as n1
        <code>
        switch (day) {
            case 1:
                name = "Pon";
                break;  // WYMAGANE!
            case 2:
                name = "Wt";
                break;
            default:
                name = "Inny";
        }
        </code>
        Pułapki: Fall-through, brak wartości
    end note
}

rectangle "Java 14+\nswitch expression" as v2 #FFF9C4 {
    note as n2
        <code>
        String name = switch (day) {
            case 1  -> "Poniedziałek";
            case 2  -> "Wtorek";
            default -> "Inny";
        };
        </code>
        Zalety: wartość zwracana, brak fall-through
    end note
}

rectangle "Java 21\nPattern Matching" as v3 #E8F5E9 {
    note as n3
        <code>
        double area = switch (shape) {
            case Circle c ->
                Math.PI * c.radius() * c.radius();
            case Rectangle r ->
                r.width() * r.height();
            case Triangle t when t.base() > 0 ->
                0.5 * t.base() * t.height();
        };
        </code>
        Zalety: typy, guarded patterns, sealed
    end note
}

v1 -right-> v2 : Java 14\n(preview)\nJava 16\n(stable)
v2 -right-> v3 : Java 21\nJEP 441\n(stable)

@enduml

