@startuml observer_pattern
skinparam classAttributeIconSize 0
skinparam defaultFontName "Segoe UI"
skinparam backgroundColor white
skinparam class {
  BackgroundColor #EEF2FF
  BorderColor #4A6CF7
}
skinparam interface {
  BackgroundColor #FFF8E1
  BorderColor #F59E0B
}

title Wzorzec Observer — EventListener jako interfejs funkcyjny

interface "EventListener<T>" <<@FunctionalInterface>> {
  + {abstract} onEvent(event : T) : void
}

class "EventBus<T>" {
  - listeners : List<EventListener<T>>
  - name : String
  + subscribe(EventListener<T>) : void
  + unsubscribe(EventListener<T>) : void
  + publish(event : T) : void
}

class TemperatureSensor <<Subject>> {
  - bus : EventBus<Double>
  - temperature : double
  + addListener(EventListener<Double>) : void
  + setTemperature(double) : void
}

"EventBus<T>"      o--> "EventListener<T>" : notifies *
TemperatureSensor  *--> "EventBus<T>"      : uses

note right of "EventListener<T>"
  @FunctionalInterface —
  mozna uzyc lambdy jako listenera:
  sensor.addListener(
    temp -> System.out.println(temp));
  sensor.addListener(
    temp -> { if(temp>35) alarm(); });
end note
@enduml


