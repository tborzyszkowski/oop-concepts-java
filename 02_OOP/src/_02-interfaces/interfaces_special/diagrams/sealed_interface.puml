@startuml sealed_interface
skinparam classAttributeIconSize 0
skinparam defaultFontName "Segoe UI"
skinparam backgroundColor white
skinparam class {
  BackgroundColor #EEF2FF
  BorderColor #4A6CF7
}
skinparam interface {
  BackgroundColor #FFF8E1
  BorderColor #F59E0B
}

title Sealed Interface (Java 17+) + Record + Pattern Matching

interface Shape <<sealed>> {
  permits Circle, Rectangle, Triangle
}

class Circle <<record>> {
  + radius : double
}

class Rectangle <<record>> {
  + width  : double
  + height : double
}

class Triangle <<record>> {
  + base   : double
  + height : double
}

Circle    ..|> Shape : implements
Rectangle ..|> Shape : implements
Triangle  ..|> Shape : implements

note right of Shape
  sealed — zamknięty zestaw klas
  Kompilator zna WSZYSTKIE podtypy
  switch BEZ default:
  switch(shape) {
    case Circle c    -> ...
    case Rectangle r -> ...
    case Triangle t  -> ...
  } // kompletny!
end note

note bottom of Circle
  record = niemodyfikowalny
  nośnik danych (Java 16+)
  — automatyczny constructor,
  gettery, equals, hashCode, toString
end note
@enduml

