@startuml command_pattern
skinparam classAttributeIconSize 0
skinparam defaultFontName "Segoe UI"
skinparam backgroundColor white
skinparam class {
  BackgroundColor #EEF2FF
  BorderColor #4A6CF7
}
skinparam interface {
  BackgroundColor #FFF8E1
  BorderColor #F59E0B
}

title Wzorzec Command — Hermetyzacja operacji jako obiekt

interface Command <<interface>> {
  + {abstract} execute() : void
  + {abstract} undo() : void
  + {abstract} description() : String
}

class TypeCommand {
  - editor : TextEditor
  - text : String
  - position : int
  + execute() : void
  + undo() : void
}

class DeleteCommand {
  - editor : TextEditor
  - from : int
  - length : int
  - deletedText : String
  + execute() : void
  + undo() : void
}

class CommandHistory <<Invoker>> {
  - history : Deque<Command>
  + execute(Command) : void
  + undo() : void
}

class TextEditor <<Receiver>> {
  - text : StringBuilder
  + insertText(s, pos) : void
  + deleteText(from, len) : void
  + getText() : String
}

TypeCommand   ..|> Command
DeleteCommand ..|> Command

CommandHistory o--> Command     : executes / undoes
TypeCommand    --> TextEditor   : modifies
DeleteCommand  --> TextEditor   : modifies

note right of CommandHistory
  Historia poleceń:
  execute() -> push na stos
  undo()    -> pop ze stosu
  Mozliwe: redo, makra, kolejki
end note
@enduml


