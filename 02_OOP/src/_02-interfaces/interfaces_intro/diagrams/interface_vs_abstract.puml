@startuml interface_vs_abstract
skinparam classAttributeIconSize 0
skinparam defaultFontName "Segoe UI"
skinparam backgroundColor white
skinparam class { BackgroundColor #EEF2FF; BorderColor #4A6CF7 }
skinparam interface { BackgroundColor #FFF8E1; BorderColor #F59E0B }
skinparam abstract { BackgroundColor #FFE4E4; BorderColor #EF4444 }

title Interfejs vs Klasa Abstrakcyjna

package "Interfejs" {
  interface Printable <<interface>> {
    + {abstract} print() : void
    ' Brak stanu (pól instancji)
    ' Brak konstruktora
    ' Wielokrotna implementacja OK
  }
}

package "Klasa abstrakcyjna" {
  abstract class AbstractShape {
    # color : String
    + {abstract} area() : double
    + describe() : String
    ' MA stan (pola instancji)
    ' MA konstruktor
    ' Tylko jedno dziedziczenie!
  }
}

class Document { + print() : void }
class Photo    { + print() : void }

class Circle   { + area() : double }
class Square   { + area() : double }

Document ..|> Printable
Photo    ..|> Printable
Circle   --|> AbstractShape
Square   --|> AbstractShape

note right of Printable
  <b>Interfejs:</b>
  - brak stanu (pól instancji)
  - wielokrotna implementacja
  - domyślnie public abstract
  - Java 8+: default, static
  - Java 9+: private
end note

note right of AbstractShape
  <b>Klasa abstrakcyjna:</b>
  - może mieć pola instancji
  - jedno dziedziczenie (extends)
  - może mieć konstruktory
  - może mieć metody konkretne
end note
@enduml

