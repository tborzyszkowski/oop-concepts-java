@startuml iterable_iterator
skinparam classAttributeIconSize 0
skinparam defaultFontName "Segoe UI"
skinparam backgroundColor white
skinparam class {
  BackgroundColor #EEF2FF
  BorderColor #4A6CF7
}
skinparam interface {
  BackgroundColor #FFF8E1
  BorderColor #F59E0B
}

title Iterable<T> i Iterator<T>

interface "Iterable<T>" <<interface>> {
  + {abstract} iterator() : Iterator<T>
}

interface "Iterator<T>" <<interface>> {
  + {abstract} hasNext() : boolean
  + {abstract} next() : T
  + remove() : void  <<default>>
}

class NumberRange {
  - start : int
  - end   : int
  - step  : int
  + iterator() : Iterator<Integer>
}

class RangeIterator <<inner>> {
  - current : int
  + hasNext() : boolean
  + next() : Integer
}

NumberRange   ..|> "Iterable<T>"
RangeIterator ..|> "Iterator<T>"
NumberRange   +-- RangeIterator : creates

note right of "Iterable<T>"
  for (int n : new NumberRange(1,10))
  // kompilator tłumaczy na:
  Iterator<Integer> it = range.iterator();
  while (it.hasNext()) { int n = it.next(); }
end note
@enduml

